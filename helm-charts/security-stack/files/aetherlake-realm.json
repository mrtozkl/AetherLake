{
  "realm": "aetherlake",
  "enabled": true,
  "attributes": {
    "frontendUrl": "http://keycloak.aetherlake.local"
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "realmRoles": ["data-admin"],
      "attributes": {
        "minio_policy": ["consoleAdmin"]
      },
      "credentials": [
        {
          "type": "password",
          "value": "$(env:REALM_ADMIN_PASSWORD)",
          "temporary": true
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "data-admin",
        "description": "Administrator for the Data Platform"
      },
      {
        "name": "data-scientist",
        "description": "Data Scientist Role"
      },
      {
        "name": "data-engineer",
        "description": "Data Engineer Role"
      }
    ]
  },
  "components": {},
  "clients": [
    {
      "clientId": "aetherlake-client",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:CONTROL_PANEL_CLIENT_SECRET)",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://panel.aetherlake.local/*"
      ],
      "protocol": "openid-connect"
    },
    {
      "clientId": "trino",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:TRINO_CLIENT_SECRET)",
      "redirectUris": ["http://trino.aetherlake.local/*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "group-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "airflow",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:AIRFLOW_CLIENT_SECRET)",
      "redirectUris": ["http://airflow.aetherlake.local/*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "group-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "groups",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "polaris",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:POLARIS_OIDC_SECRET)",
      "redirectUris": [],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "principal-id-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "principal_id",
            "claim.value": "0",
            "jsonType.label": "long",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "principal-name-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "principal_name",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        },
        {
          "name": "principal-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "principal_roles",
            "claim.value": "[\"server_admin\", \"catalog_admin\"]",
            "jsonType.label": "JSON",
            "access.token.claim": "true",
            "id.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "minio",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "secret": "$(env:MINIO_OIDC_SECRET)",
      "redirectUris": ["http://minio.aetherlake.local/*"],
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "policy-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "minio_policy",
            "claim.name": "policy",
            "jsonType.label": "String",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        }
      ]
    },
    {
      "clientId": "superset",
      "enabled": true,
      "publicClient": false,
      "secret": "$(env:SUPERSET_OIDC_SECRET)",
      "redirectUris": ["http://superset.aetherlake.local/*"],
      "protocol": "openid-connect"
    }
  ]
}
